.container {
  padding: var(--spacing-md);
}

.loading {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-state, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.error-text {
  color: var(--text-secondary);
  font-size: var(--font-md);
  margin-bottom: var(--spacing-lg);
}

.retry-btn {
  background: var(--primary-color);
  color: white;
  border-radius: var(--radius-md);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-lg);
}

.empty-text {
  color: var(--text-hint);
  font-size: var(--font-md);
  text-align: center;
  line-height: 1.6;
}

.header {
  margin-bottom: var(--spacing-md);
}

.analytics-btn {
  background: var(--primary-color);
  color: white;
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  height: 80rpx;
  line-height: 80rpx;
}

.trip-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.trip-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  gap: var(--spacing-md);
}

.trip-date-box {
  width: 96rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.trip-date-box.has-catch {
  background: var(--primary-light);
}

.trip-date-box.no-catch {
  background: var(--danger-light);
}

.trip-date-text {
  font-size: var(--font-sm);
  font-weight: bold;
}

.trip-date-box.has-catch .trip-date-text {
  color: var(--primary-color);
}

.trip-date-box.no-catch .trip-date-text {
  color: var(--danger-color);
}

.trip-time-text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.trip-info {
  flex: 1;
  min-width: 0;
}

.trip-info-top {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-xs);
}

.trip-spot {
  font-size: var(--font-md);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.trip-info-bottom {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
}

.tag {
  padding: 2rpx var(--spacing-sm);
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  font-weight: bold;
}

.tag-blue {
  background: var(--primary-light);
  color: var(--primary-color);
}

.tag-red {
  background: var(--danger-light);
  color: var(--danger-color);
}

.tag-gray {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.trip-species {
  font-size: var(--font-xs);
  color: var(--text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.trip-arrow {
  color: var(--text-hint);
  font-size: var(--font-xl);
  flex-shrink: 0;
}
