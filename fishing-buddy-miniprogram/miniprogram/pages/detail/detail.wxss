.container {
  padding: var(--spacing-md);
}

.loading {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.error-state, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.error-text, .text {
  color: var(--text-secondary);
  font-size: var(--font-md);
}

.detail-content {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.card-icon {
  font-size: var(--font-lg);
  margin-right: var(--spacing-sm);
}

.card-title {
  font-size: var(--font-lg);
  font-weight: bold;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid var(--bg-color);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: var(--text-secondary);
  font-size: var(--font-sm);
  min-width: 120rpx;
}

.info-value {
  font-size: var(--font-md);
  text-align: right;
}

.empty-catch {
  padding: var(--spacing-lg);
  text-align: center;
}

.empty-catch-text {
  color: var(--text-hint);
  font-size: var(--font-sm);
}

.species-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.species-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  padding: var(--spacing-sm) 0;
}

.species-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.species-name {
  flex: 1;
  font-size: var(--font-md);
  font-weight: 500;
}

.species-count-tag {
  background: var(--primary-light);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-sm);
}

.species-count-text {
  font-size: var(--font-sm);
  font-weight: bold;
  color: var(--primary-color);
}

.notes-text {
  font-size: var(--font-md);
  color: var(--text-secondary);
  line-height: 1.6;
}
